{
  "name": "mcp-app-ext-server",
  "version": "0.2.0",
  "private": true,
  "description": "Conductor's active layer: callable host capability checks, matrix validation, app scanning, guidance and scaffolding.",
  "type": "module",
  "bin": {
    "mcp-app-ext": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "validate:matrix": "node validate-matrix.mjs",
    "smoke": "npm run build && node smoke.mjs",
    "test": "npm run typecheck && npm run validate:matrix && npm run smoke"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "ajv": "^8.20.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
