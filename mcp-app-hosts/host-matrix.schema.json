{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/dc995/mcp-app-skills/mcp-app-hosts/host-matrix.schema.json",
  "title": "MCP App host capability matrix",
  "type": "object",
  "required": ["schemaVersion", "revision", "hosts"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "revision": { "type": "string", "format": "date" },
    "notes": { "type": "string" },
    "hosts": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/$defs/host" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "status": {
      "oneOf": [
        { "type": "boolean" },
        { "const": "unvalidated" },
        { "const": "varies" }
      ]
    },
    "evidence": {
      "type": "object",
      "required": ["kind", "date", "source", "summary"],
      "properties": {
        "kind": { "enum": ["upstream", "empirical"] },
        "date": { "type": "string", "format": "date" },
        "source": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "host": {
      "type": "object",
      "required": [
        "name",
        "transport",
        "tls",
        "csp",
        "sandbox",
        "server-initiated",
        "secure-context",
        "features",
        "bundling",
        "last-validated",
        "evidence"
      ],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "transport": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string" }
        },
        "tls": { "type": "boolean" },
        "csp": { "type": "object" },
        "sandbox": {
          "type": "object",
          "properties": {
            "notes": { "type": "string" }
          },
          "additionalProperties": { "$ref": "#/$defs/status" }
        },
        "server-initiated": {
          "type": "object",
          "required": [
            "sampling",
            "elicitation",
            "resource-subscriptions",
            "requires-stateful-transport"
          ],
          "properties": {
            "sampling": { "$ref": "#/$defs/status" },
            "elicitation": { "$ref": "#/$defs/status" },
            "resource-subscriptions": { "$ref": "#/$defs/status" },
            "requires-stateful-transport": { "type": "boolean" },
            "notes": { "type": "string" }
          },
          "additionalProperties": false
        },
        "secure-context": { "type": "boolean" },
        "iframe-origin": { "type": "string" },
        "features": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/status" }
        },
        "bundling": { "type": "object" },
        "port-config": { "type": "object" },
        "authoring": { "type": "object" },
        "known-broken-patterns": {
          "type": "array",
          "items": { "type": "string" }
        },
        "known-working-patterns": {
          "type": "array",
          "items": { "type": "string" }
        },
        "last-validated": { "type": "string", "format": "date" },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/evidence" }
        }
      },
      "additionalProperties": false
    }
  }
}
